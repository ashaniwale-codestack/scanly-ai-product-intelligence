
Run Backend Project
go to root folder and run

cd D:\Project\Hackthon\Ingredient_Scanner
# (optional) create + activate venv (recommended once) 
# run powershell using admin
python -m venv .venv .\.venv\Scripts\Activate.ps1 

# install backend deps
pip install -r backend\requirements.txt

# run backend (run as package so 'routers' imports resolve)
uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000
python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000



Run Frontend
# from the flutter_web folder (requires Flutter SDK installed)
flutter pub get
flutter run -d chrome






Get-ChildItem -Force .venv
