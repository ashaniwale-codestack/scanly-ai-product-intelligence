# -----------------------------
# Stage 1: Build Flutter Web
# -----------------------------
FROM cirrusci/flutter:stable AS flutter-build

WORKDIR /app/frontend

# Copy Flutter project files and get dependencies
COPY frontend/pubspec.* ./
RUN flutter pub get
COPY frontend/ .

# Build Flutter web
RUN flutter build web --release

# -----------------------------
# Stage 2: Build FastAPI Backend
# -----------------------------
FROM python:3.11-slim

WORKDIR /app

# Install backend dependencies
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend source code
COPY backend/ ./backend

# Copy Flutter web build to FastAPI static folder
COPY --from=flutter-build /app/frontend/build/web /app/backend/static

# Expose the port FastAPI will run on
EXPOSE 8000

# Run backend (as package) and serve Flutter web
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
